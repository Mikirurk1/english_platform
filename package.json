{
  "name": "soenglish",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/*/*"
  ],
  "scripts": {
    "predev": "node scripts/free-dev-ports.cjs && npm run build:email-templates && npm run prisma:generate",
    "dev": "turbo run dev --filter=@app/web --filter=@app/api",
    "dev:web": "turbo run dev --filter=@app/web",
    "brand:icons": "node scripts/generate-brand-icons.mjs",
    "predev:api": "npm run prisma:generate",
    "dev:api": "turbo run dev --filter=@app/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@app/web",
    "build:api": "turbo run build --filter=@app/api",
    "lint": "turbo run lint",
    "typecheck": "npm run build:email-templates && turbo run typecheck",
    "build:email-templates": "npm run build -w @be/email-templates",
    "prisma:generate": "prisma generate --schema packages/backend/data-access/data-access-prisma/prisma/schema.prisma",
    "prisma:seed:languages": "tsx packages/backend/data-access/data-access-prisma/prisma/seed-languages.ts",
    "prisma:backfill:languages-words": "tsx packages/backend/data-access/data-access-prisma/prisma/backfill-languages-words.ts",
    "prisma:migrate:native-language": "tsx packages/backend/data-access/data-access-prisma/prisma/migrate-native-language-legacy.ts",
    "prisma:migrate:dev": "prisma migrate dev --schema packages/backend/data-access/data-access-prisma/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema packages/backend/data-access/data-access-prisma/prisma/schema.prisma",
    "prisma:studio": "prisma studio",
    "prisma:migrate:rebaseline": "node scripts/prisma-rebaseline-migrations.cjs",
    "super-admin": "tsx scripts/super-admin.ts",
    "seed:test-users": "tsx scripts/seed-test-users.ts",
    "test:translation-matrix": "tsx scripts/translation-matrix-browser.mjs",
    "test:translation-matrix:api": "tsx scripts/translation-matrix-run.mjs",
    "coursework:generate": "node scripts/generate-coursework-docx.mjs && node scripts/export-coursework-md.mjs",
    "test": "npm run build:email-templates && jest",
    "test:unit": "npm run prisma:generate && npm run build:email-templates && jest --selectProjects module-auth module-vocabulary module-chat module-lessons module-flashcards module-speaking module-materials module-notifications module-progress module-mail web",
    "test:coverage": "npm run build:email-templates && jest --coverage --selectProjects module-auth module-vocabulary module-chat module-lessons module-flashcards module-speaking module-materials module-notifications module-progress module-mail web",
    "test:coverage:integration": "npm run build:email-templates && RUN_INTEGRATION_TESTS=1 jest --config jest.integration.config.cjs --coverage",
    "test:integration": "npm run build:email-templates && RUN_INTEGRATION_TESTS=1 jest --config jest.integration.config.cjs",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "lint:styles": "node scripts/style-guardrails.cjs",
    "docker:restore": "bash scripts/docker-restore-all.sh",
    "docker:restore:stack": "bash scripts/docker-restore-all.sh --stack",
    "docker:up": "bash scripts/docker-wait-engine.sh && docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:libretranslate": "bash scripts/docker-wait-engine.sh && docker compose -f infra/docker/docker-compose.yml up -d libretranslate",
    "docker:libretranslate:logs": "docker compose -f infra/docker/docker-compose.yml logs -f libretranslate",
    "docker:postgres": "npm run docker:up",
    "docker:stack": "node scripts/free-dev-ports.cjs && bash scripts/docker-wait-engine.sh && docker compose -f infra/docker/docker-compose.yml --profile stack up -d --build",
    "docker:stack:down": "docker stop soenglish-api soenglish-web 2>/dev/null || true",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "docker:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "docker:ps": "docker compose -f infra/docker/docker-compose.yml ps -a",
    "lockfile:linux": "docker run --rm -v \"$PWD:/app\" -w /app node:22-bookworm-slim bash -c 'corepack enable && corepack prepare npm@11.6.2 --activate && npm install'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.51.1",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@swc/jest": "^0.2.37",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "20.19.9",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.3",
    "docx": "^9.6.1",
    "eslint": "^9.8.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "~3.6.2",
    "prisma": "^7.7.0",
    "sass": "1.62.1",
    "supertest": "^7.1.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0",
    "tsx": "^4.20.6",
    "turbo": "^2.5.5",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.4.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/graphql": "^13.4.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.7.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "graphql": "^16.14.0",
    "graphql-request": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.4",
    "lucide-react": "^1.14.0",
    "next": "~16.1.6",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "stripe": "^18.5.0",
    "zustand": "^5.0.12"
  }
}
